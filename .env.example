# ============================================
# SentinelAI Mission Control — Environment Config
# ============================================
# Copy this to .env and fill in your values

# --- Application ---
APP_NAME=SentinelAI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production
API_V1_PREFIX=/api/v1

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_secret_2024
POSTGRES_DB=sentinel_db
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_secret_2024@postgres:5432/sentinel_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
